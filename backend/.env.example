# Runtime profile: local for development, prod on Render.
SPRING_PROFILES_ACTIVE=local

# Use a Supabase PostgreSQL JDBC URL. Keep sslmode=require.
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DB_SSL_MODE=require

# Generate at least 32 random bytes and Base64-encode them.
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRY=7d

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Reserved for later phases. They may remain empty in Phase 1.
BREVO_API_KEY=
EMAIL_PROVIDER=log
EMAIL_SENDER_EMAIL=
EMAIL_SENDER_NAME=BurgerBurst
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Phase 5 production tuning. Defaults are safe for a single instance.
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL_REQUESTS=300
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_OTP_REQUESTS=5
RATE_LIMIT_ANALYTICS_REQUESTS=120
